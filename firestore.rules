// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: /users/{userId}/profile/data
// Fields:
//   - uid: string (required, immutable) - Firebase Auth UID
//   - email: string (required) - User's email
//   - displayName: string (optional) - User's name
//   - photoURL: string (optional) - Profile pic
//   - createdAt: string (required, immutable) - Creation timestamp
//
// Collection: /users/{userId}/exams/{examId}
// Fields:
//   - id: string (required)
//   - uid: string (required, immutable)
//   - title: string (required)
//   - subject: string (required)
//   - grade: string (required)
//   - createdAt: string (required, immutable)
//   - matrix: string (required)
//   - specs: string (required)
//   - exam: string (required)
//
// Collection: /users/{userId}/questions/{questionId}
// Fields:
//   - id: string (required)
//   - uid: string (required, immutable)
//   - subject: string (required)
//   - grade: string (required)
//   - lesson: string (optional)
//   - type: string (required, enum)
//   - level: string (required, enum)
//   - content: string (required)
//   - answer: string (optional)
//   - createdAt: string (required, immutable)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Rules for user-owned subcollections (exams, questions, profile)
    // Matches any document under users/{userId}/...
    match /users/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId);
    }

    // Admin override: Full access for the developer/administrator
    match /{document=**} {
      allow read, write: if isSignedIn() && 
        request.auth.token.email == "nttkiemtra@gmail.com" && 
        request.auth.token.email_verified == true;
    }
    
    // Default deny for everything else not explicitly covered above
    // (Though the admin check above acts as a broad allow for one user)
    match /admins/{adminId} {
      allow read: if isSignedIn() && (
        request.auth.token.email == "nttkiemtra@gmail.com" && 
        request.auth.token.email_verified == true
      );
      allow write: if false;
    }
  }
}
